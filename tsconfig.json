{
  "compilerOptions": {
    "target": "esnext",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "declaration": true,
    "emitDeclarationOnly": true,
    "noErrorTruncation": true,
    "allowJs": true,
    "esModuleInterop": true,
    "useDefineForClassFields": false,
  }
}
