{
  "name": "@casl/vue",
  "version": "2.2.6",
  "description": "Vue plugin for CASL which makes it easy to add permissions in any Vue application",
  "module": "./dist/esm/index.mjs",
  "types": "./dist/types/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/esm/index.mjs"
    }
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/stalniy/casl.git",
    "directory": "packages/casl-vue"
  },
  "homepage": "https://casl.js.org",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build.prepare": "rm -rf dist/* && dx tsc",
    "build": "npm run build.prepare && dx tsdown",
    "lint": "dx eslint src/ spec/",
    "test": "dx jest --env jsdom",
    "release.prepare": "npm run lint && npm test && NODE_ENV=production npm run build",
    "release": "npm run release.prepare && pnpm publish"
  },
  "keywords": [
    "casl",
    "vue",
    "authorization",
    "acl",
    "permissions"
  ],
  "author": "Sergii Stotskyi <sergiy.stotskiy@gmail.com>",
  "license": "MIT",
  "peerDependencies": {
    "@casl/ability": "^2.0.0 || ^3.0.0 || ^4.0.0 || ^5.1.0 || ^6.0.0",
    "vue": "^3.0.0"
  },
  "devDependencies": {
    "@casl/ability": "^6.0.0",
    "@casl/dx": "workspace:^1.0.0",
    "@types/jest": "^30.0.0",
    "chai": "^6.0.0",
    "chai-spies": "^1.0.0",
    "vue": "^3.2.45"
  },
  "files": [
    "dist"
  ]
}
